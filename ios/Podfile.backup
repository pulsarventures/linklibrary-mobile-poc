# Resolve react_native_pods.rb with node to allow for hoisting
require_relative '../node_modules/react-native/scripts/react_native_pods'

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Disable codegen and new architecture
ENV['RCT_NEW_ARCH_ENABLED'] = '0'
ENV['RCT_FABRIC_ENABLED'] = '0'
ENV['RCT_TURBO_MODULE_ENABLED'] = '0'

# Use modular headers for Firebase
# use_modular_headers!

# Use frameworks for Firebase compatibility
use_frameworks! :linkage => :static

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'linklibrary_mobile' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    # Disable new architecture completely
    :fabric_enabled => false,
    :hermes_enabled => true
  )

  # Add Firebase pods
  pod 'Firebase/Core'
  pod 'Firebase/Auth'
  
  # Temporarily exclude react-native-mmkv to fix codegen issue
  pod 'react-native-mmkv', :path => '../node_modules/react-native-mmkv', :inhibit_warnings => true

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    
    # Disable New Architecture to avoid module conflicts
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['RCT_NEW_ARCH_ENABLED'] = '0'
        config.build_settings['RCT_FABRIC_ENABLED'] = '0'
        config.build_settings['RCT_TURBO_MODULE_ENABLED'] = '0'
      end
    end
  end
end
